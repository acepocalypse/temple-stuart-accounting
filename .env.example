# Manual Stock Scanner (minimal environment)
# Copy to .env.local

# Required: Finnhub market/fundamental data
FINNHUB_API_KEY="your-finnhub-key"

# Required: FRED macro regime data
FRED_API_KEY="your-fred-key"

# Optional: Gemini plain-English narration
# Used only for narrative summaries; never used for scores/thresholds/sizing.
GEMINI_API_KEY="your-gemini-api-key"
# Optional aliases:
# GOOGLE_API_KEY="your-gemini-api-key"
# GENAI_API_KEY="legacy-key"

# Optional: App URL (used for links/metadata if needed)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Scheduler (optional, for always-on Docker/remote operation)
SCHEDULER_ENABLED="false"
SCHEDULER_USER_KEY="manual-stock-user"
SCHEDULER_TIMEZONE="America/New_York"
SCHEDULER_WINDOW_START_ET="04:00"
SCHEDULER_WINDOW_END_ET="16:00"
SCHEDULER_DAILY_SCAN_TIME_ET="09:20"
SCHEDULER_REFRESH_MINUTES="15"
SCHEDULER_FALLBACK_RESCAN_MINUTES="60"
SCHEDULER_FALLBACK_POOL_MIN="5"
SCHEDULER_STATE_PATH="/data/scheduler-state.json"

# Telegram notifications (optional; required for scheduler phone alerts)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# Alpaca paper trading automation (optional, disabled by default)
ALPACA_PAPER_TRADING_ENABLED="false"
ALPACA_API_KEY="your-alpaca-key-id"
ALPACA_API_SECRET="your-alpaca-secret-key"
ALPACA_BASE_URL="https://paper-api.alpaca.markets"
# Comma-separated modes: daily,refresh,fallback_rescan
ALPACA_EXECUTE_ON="refresh"
ALPACA_MAX_ORDERS_PER_RUN="3"
ALPACA_NOTIONAL_USD="1000"
ALPACA_ORDER_TAKE_PROFIT_R_MULT="1"
