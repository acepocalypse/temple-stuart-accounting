# Manual Stock Scanner (minimal environment)
# Copy to .env.local

# Required: Finnhub market/fundamental data
FINNHUB_API_KEY="your-finnhub-key"

# Required: FRED macro regime data
FRED_API_KEY="your-fred-key"

# Optional: Gemini plain-English narration
# Used only for narrative summaries; never used for scores/thresholds/sizing.
GEMINI_API_KEY="your-gemini-api-key"
# Optional aliases:
# GOOGLE_API_KEY="your-gemini-api-key"
# GENAI_API_KEY="legacy-key"

# Optional: App URL (used for links/metadata if needed)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
